OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxx

# Modèle principal — voir https://openrouter.ai/models
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Fallbacks utilisés automatiquement si le modèle principal est rate-limité (429)
# OpenRouter limite cette liste à 3 entrées max
OPENROUTER_FALLBACKS=openai/gpt-oss-120b:free,meta-llama/llama-3.3-70b-instruct:free,deepseek/deepseek-chat-v3.1:free
